# Application
SECRET_KEY=replace-with-256-bit-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# Database (path inside container when using docker-compose)
DATABASE_URL=sqlite:///./portfolio_intel.db

# Anthropic / Claude
ANTHROPIC_API_KEY=your_key_here

# Apollo.io
APOLLO_API_KEY=your_key_here

# Gmail SMTP (App Password — NOT your account password)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=alerts@yourfirm.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Alert recipients (comma-separated)
ALERT_RECIPIENTS=partner1@firm.com,partner2@firm.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Scheduler (UTC)
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0

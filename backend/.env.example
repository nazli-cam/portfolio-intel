# Application
SECRET_KEY=your-secret-key-change-this-in-production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=development

# Database
# Local dev (Docker Compose spins up Postgres automatically):
DATABASE_URL=postgresql://portfolio:portfolio@db:5432/portfolio_intel
# Railway (set in Railway dashboard → Variables):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Anthropic / Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Apollo.io
APOLLO_API_KEY=your-apollo-api-key

# Gmail SMTP (App Password — NOT your account password)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
# Generate a password for "Mail" and paste the 16-char string below
GMAIL_USER=alerts@yourfirm.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Alert recipients (comma-separated)
ALERT_EMAIL_RECIPIENTS=partner1@yourfirm.com,partner2@yourfirm.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Scheduler (UTC)
DAILY_SCHEDULER_HOUR=8
DAILY_SCHEDULER_MINUTE=0
